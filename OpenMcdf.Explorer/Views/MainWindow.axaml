<Window
    x:Class="OpenMcdf.Explorer.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avaloniaHex="clr-namespace:AvaloniaHex;assembly=AvaloniaHex"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rendering="clr-namespace:AvaloniaHex.Rendering;assembly=AvaloniaHex"
    xmlns:vm="using:OpenMcdf.Explorer.ViewModels"
    Title="OpenMcdf Explorer"
    d:DesignHeight="600"
    d:DesignWidth="1000"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Command="{Binding TryCreateNewFileCommand}" Header="New Compound File">
                    <MenuItem.Icon>
                        <Image Source="avares://OpenMcdf.Explorer/Assets/page_white.png" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Command="{Binding TryOpenFileCommand}" Header="Open...">
                    <MenuItem.Icon>
                        <Image Source="avares://OpenMcdf.Explorer/Assets/folder.png" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Command="{Binding TryCloseCurrentFileCommand}"
                    Header="Close File"
                    IsEnabled="{Binding IsDocumentLoaded}" />

                <Separator />

                <MenuItem
                    Command="{Binding TrySaveCommand}"
                    Header="Save"
                    IsEnabled="{Binding IsDocumentLoaded}">
                    <MenuItem.Icon>
                        <Image Source="avares://OpenMcdf.Explorer/Assets/disk.png" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    Command="{Binding TrySaveAsCommand}"
                    Header="Save As..."
                    IsEnabled="{Binding IsDocumentLoaded}" />
            </MenuItem>
        </Menu>

        <!--  Status bar  -->
        <Border
            Padding="8,3"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            DockPanel.Dock="Bottom">
            <TextBlock VerticalAlignment="Center" Text="{Binding FilePath}" />
        </Border>

        <!--  Main content  -->
        <Grid Margin="4" ColumnDefinitions="300,4,*">

            <!--  Left panel: tree + entry properties  -->
            <Grid Grid.Column="0" RowDefinitions="*,4,180">

                <Border
                    Grid.Row="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TreeView
                        x:Name="MainTreeView"
                        BorderThickness="0"
                        ItemsSource="{Binding Nodes}"
                        SelectionChanged="MainTreeView_SelectionChanged">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding SubNodes}">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,4,0"
                                        Source="{Binding IconSource}" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                        <TreeView.ContextMenu>
                            <ContextMenu x:CompileBindings="False">
                                <MenuItem
                                    Command="{Binding AddStorageCommand}"
                                    Header="Add Storage..."
                                    IsEnabled="{Binding IsStorageSelected}" />
                                <MenuItem
                                    Command="{Binding AddStreamCommand}"
                                    Header="Add Stream..."
                                    IsEnabled="{Binding IsStorageSelected}" />
                                <Separator />
                                <MenuItem
                                    Command="{Binding ImportDataCommand}"
                                    Header="Import data..."
                                    IsEnabled="{Binding IsStreamSelected}" />
                                <MenuItem
                                    Command="{Binding ExportDataCommand}"
                                    Header="Export data..."
                                    IsEnabled="{Binding IsStreamSelected}" />
                                <Separator />
                                <MenuItem
                                    Command="{Binding RemoveEntryCommand}"
                                    Header="Remove"
                                    IsEnabled="{Binding IsNodeSelected}" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </Border>

                <GridSplitter
                    Grid.Row="1"
                    Height="4"
                    HorizontalAlignment="Stretch"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                    ResizeDirection="Rows" />

                <Border
                    Grid.Row="2"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <DataGrid
                        AutoGenerateColumns="False"
                        BorderThickness="0"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="False"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="None"
                        IsReadOnly="True"
                        ItemsSource="{Binding EntryProperties}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Width="Auto"
                                Binding="{Binding Key}"
                                Header="Property" />
                            <DataGridTextColumn
                                Width="*"
                                Binding="{Binding Value}"
                                Header="Value" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                ResizeDirection="Columns" />

            <!--  Right panel: tabs  -->
            <TabControl
                Grid.Column="2"
                Padding="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <TabControl.Styles>
                    <Style Selector="TabItem">
                        <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
                        <Setter Property="BorderThickness" Value="1,1,1,0" />
                        <Setter Property="CornerRadius" Value="4,4,0,0" />
                        <Setter Property="Margin" Value="0,0,2,0" />
                    </Style>
                </TabControl.Styles>
                <TabItem Header="Raw Data">
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0">
                        <avaloniaHex:HexEditor Document="{Binding HexDocument}" FontFamily="Cascadia Code,Consolas,Monospace,monospace">
                            <avaloniaHex:HexEditor.Columns>
                                <rendering:OffsetColumn />
                                <rendering:HexColumn />
                                <rendering:AsciiColumn />
                            </avaloniaHex:HexEditor.Columns>
                        </avaloniaHex:HexEditor>
                    </Border>
                </TabItem>

                <TabItem Header="OLE Properties">
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0">
                        <Grid Margin="0,4,0,0" RowDefinitions="*,Auto,*">
                            <DataGrid
                                Grid.Row="0"
                                AutoGenerateColumns="False"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                CanUserSortColumns="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding OleProperties}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Name}"
                                        Header="Name" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Type}"
                                        Header="Type" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Value}"
                                        Header="Value" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border
                                Grid.Row="1"
                                Margin="0,8,0,0"
                                Padding="4,4,4,2"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="0,0,0,1">
                                <TextBlock FontWeight="SemiBold" Text="User-Defined Properties" />
                            </Border>

                            <DataGrid
                                Grid.Row="2"
                                AutoGenerateColumns="False"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="True"
                                CanUserSortColumns="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding UserDefinedProperties}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Name}"
                                        Header="Name" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Type}"
                                        Header="Type" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Value}"
                                        Header="Value" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
